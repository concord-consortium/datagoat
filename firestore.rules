rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data. The wildcard {document=**}
    // covers profile, wellnessEntries/{date}, and performanceEntries/{date} -
    // every future user-scoped subcollection inherits owner-only access
    // automatically.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
