# Functions params for the production datagoat-b07dd project. Loaded by the
# Firebase CLI at deploy time when targeting -P datagoat-b07dd. Without this
# file, `firebase deploy --only functions` fails in non-interactive mode
# because defineString with a default still requires an explicit value source.
#
# Kill switch: set this to false and run `npm run deploy:production:functions` to
# disable the Facebook no-email rejection rule on production without a code change.
# This is per-project - flipping it here does not affect staging.
FACEBOOK_BLOCKER_ENABLED=true
