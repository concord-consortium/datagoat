VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# The emulator toggle is NOT set here — it lives in .env.emulators,
# .env.cloud, or .env.production (all committed) and is selected by
# Vite's --mode flag in the npm scripts (`dev` -> emulators,
# `dev:cloud` -> cloud, `build` -> production). See CLAUDE.md.
#
# If you previously had VITE_USE_EMULATORS=true in your .env.local
# from the old workflow, remove it. The mode-scoped files override it
# everywhere it matters, but a stale line in your local config is
# still misleading.
