# Template for your personal .env.local (untracked). Copy to .env.local and
# fill in the real values from the Firebase console (or the team's password
# manager entry for the DataGOAT projects).
#
# These are SOURCE-OF-TRUTH vars for both cloud environments. They deliberately
# do NOT use the VITE_ prefix: Vite only exposes VITE_-prefixed vars to the
# client bundle, so prefixing these would bundle BOTH project IDs into every
# build and defeat the "one project per build" guarantee. Instead they live in
# the build-time environment only and are referenced via ${VAR} expansion from
# the committed .env.staging / .env.production files, which add the VITE_ prefix
# for exactly one environment per build. See CLAUDE.md (Environments).
#
# Copy values verbatim from the console. The storage bucket may be the legacy
# *.appspot.com form on older projects or the newer *.firebasestorage.app form
# on projects created after the migration - use whatever the console shows.

FIREBASE_STAGING_API_KEY=
FIREBASE_STAGING_AUTH_DOMAIN=
FIREBASE_STAGING_PROJECT_ID=
FIREBASE_STAGING_STORAGE_BUCKET=
FIREBASE_STAGING_MESSAGING_SENDER_ID=
FIREBASE_STAGING_APP_ID=
FIREBASE_STAGING_MEASUREMENT_ID=

FIREBASE_PRODUCTION_API_KEY=
FIREBASE_PRODUCTION_AUTH_DOMAIN=
FIREBASE_PRODUCTION_PROJECT_ID=
FIREBASE_PRODUCTION_STORAGE_BUCKET=
FIREBASE_PRODUCTION_MESSAGING_SENDER_ID=
FIREBASE_PRODUCTION_APP_ID=
FIREBASE_PRODUCTION_MEASUREMENT_ID=
