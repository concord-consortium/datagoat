# Loaded by `vite build` / `vite --mode production` (dev:production / build:production /
# deploy:production / deploy:production:hosting). Forces emulators off so production bundles are immune
# to a stale VITE_USE_EMULATORS=true left in any developer's .env.local, and
# pulls the production Firebase config from the FIREBASE_PRODUCTION_* source
# vars in .env.local via Vite's ${VAR} expansion. The VITE_ prefix lives here
# (committed) - NOT on the source vars - so only one project's config is ever
# bundled into a given build. See CLAUDE.md.
VITE_USE_EMULATORS=false
VITE_FIREBASE_API_KEY=${FIREBASE_PRODUCTION_API_KEY}
VITE_FIREBASE_AUTH_DOMAIN=${FIREBASE_PRODUCTION_AUTH_DOMAIN}
VITE_FIREBASE_PROJECT_ID=${FIREBASE_PRODUCTION_PROJECT_ID}
VITE_FIREBASE_STORAGE_BUCKET=${FIREBASE_PRODUCTION_STORAGE_BUCKET}
VITE_FIREBASE_MESSAGING_SENDER_ID=${FIREBASE_PRODUCTION_MESSAGING_SENDER_ID}
VITE_FIREBASE_APP_ID=${FIREBASE_PRODUCTION_APP_ID}
VITE_FIREBASE_MEASUREMENT_ID=${FIREBASE_PRODUCTION_MEASUREMENT_ID}
