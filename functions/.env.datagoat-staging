# Functions params for the staging datagoat-staging project. Loaded by the
# Firebase CLI at deploy time when targeting -P staging. Without this file,
# `firebase deploy --only functions` fails in non-interactive mode because
# defineString with a default still requires an explicit value source.
#
# Kill switch: set this to false and run `npm run deploy:staging:functions` to
# disable the Facebook no-email rejection rule on staging without a code change.
# This is per-project - flipping it here does not affect production.
FACEBOOK_BLOCKER_ENABLED=true
