# Functions params for the demo-datagoat emulator project. Loaded by the
# Functions emulator when started with --project=demo-datagoat (see the
# `emulators` script in the repo-root package.json). Without this file the
# emulator prompts interactively for FACEBOOK_BLOCKER_ENABLED on each start
# and stdin-less invocations (CI, background tasks) hang forever.
#
# Production deploys ignore this file — they target a different projectId
# (datagoat-b07dd) and read the param from the Firebase console.
FACEBOOK_BLOCKER_ENABLED=true
