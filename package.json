{
  "name": "datagoat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "emulators": "firebase emulators:start --only auth,firestore,hosting,functions --project=demo-datagoat --import=./firebase-data --export-on-exit",
    "deploy": "npm run build && firebase deploy --only hosting,functions,firestore:rules -P datagoat-b07dd",
    "deploy:functions": "firebase deploy --only functions -P datagoat-b07dd",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "report:bundle": "node tools/bundle-size-report.mjs"
  },
  "dependencies": {
    "@concord-consortium/codap-plugin-api": "^0.1.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.2.2",
    "firebase": "^12.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5"
  }
}
