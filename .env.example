VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# The emulator toggle is NOT set here — it lives in .env.emulators or
# .env.cloud (both committed) and is selected by Vite's --mode flag in
# the npm scripts (`dev` -> emulators, `dev:cloud` -> cloud). See CLAUDE.md.
#
# If you previously had VITE_USE_EMULATORS=true in your .env.local from
# the old workflow, remove it: .env.local is loaded for ALL modes, so a
# stale value there can override the intent of `npm run dev:cloud` and
# leak into production builds.
